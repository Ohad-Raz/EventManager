@model EventManager.WebApp.ViewModels.EventSearchVM

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Event Type</th>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Location</th>
            <th>Capacity</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Events)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.EventTypeName</td>
                <td>@item.StartTime</td>
                <td>@item.EndTime</td>
                <td>@item.Location</td>
                <td>@item.Capacity</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex flex-wrap justify-content-between align-items-center mt-3 gap-2">
    <p class="mb-0 text-muted">Page @Model.Page of @Model.LastPage</p>

    <div class="btn-group" role="group" aria-label="Event search paging">
        @if (Model.HasPreviousPage)
        {
            <a asp-action="Search"
               asp-route-Q="@Model.Q"
               asp-route-EventTypeId="@Model.EventTypeId"
               asp-route-OrderBy="@Model.OrderBy"
               asp-route-Size="@Model.Size"
               asp-route-Page="@(Model.Page - 1)"
               class="btn btn-outline-primary page-link">Previous</a>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled>Previous</button>
        }

        @for (int i = 1; i <= Model.LastPage; i++)
        {
            if (i == Model.Page)
            {
                <button type="button" class="btn btn-primary" disabled>@i</button>
            }
            else
            {
                <a asp-action="Search"
                   asp-route-Q="@Model.Q"
                   asp-route-EventTypeId="@Model.EventTypeId"
                   asp-route-OrderBy="@Model.OrderBy"
                   asp-route-Size="@Model.Size"
                   asp-route-Page="@i"
                   class="btn btn-outline-primary page-link">@i</a>
            }
        }

        @if (Model.HasNextPage)
        {
            <a asp-action="Search"
               asp-route-Q="@Model.Q"
               asp-route-EventTypeId="@Model.EventTypeId"
               asp-route-OrderBy="@Model.OrderBy"
               asp-route-Size="@Model.Size"
               asp-route-Page="@(Model.Page + 1)"
               class="btn btn-outline-primary page-link">Next</a>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled>Next</button>
        }
    </div>
</div>