@model EventManager.WebApp.ViewModels.EventVM

@{
    ViewData["Title"] = "Details";
    bool isAdmin = User.Identity?.IsAuthenticated == true && User.IsInRole("Admin");
    bool isUser = User.Identity?.IsAuthenticated == true && User.IsInRole("User");
    bool isAnonymous = User.Identity?.IsAuthenticated != true;
    bool isAlreadyRegistered = ViewBag.IsAlreadyRegistered == true;
}

<h1>Details</h1>

@if (TempData["RegistrationSuccess"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["RegistrationSuccess"]
    </div>
}
@if (TempData["RegistrationDuplicate"] != null)
{
    <div class="alert alert-warning" role="alert">
        @TempData["RegistrationDuplicate"]
    </div>
}
@if (TempData["RegistrationError"] != null)
{
    <div class="alert alert-danger" role="alert">
        @TempData["RegistrationError"]
    </div>
}
@if (TempData["PerformerSuccess"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["PerformerSuccess"]
    </div>
}
@if (TempData["PerformerError"] != null)
{
    <div class="alert alert-danger" role="alert">
        @TempData["PerformerError"]
    </div>
}

<div>
    <h4>Event</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.StartTime)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.StartTime)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.EndTime)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.EndTime)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Location)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Location)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Capacity)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Capacity)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.EventTypeName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.EventTypeName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CreatedByEmail)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CreatedByEmail)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ImageFileName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ImageFileName)
        </dd>
    </dl>
</div>

@* Displays performers assigned to this event. *@
<h4 class="mt-4">Performers</h4>

@if (Model.Performers.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Bio</th>
                    @if (isAdmin)
                    {
                        <th></th>
                    }
                </tr>
            </thead>
            <tbody>
            @foreach (var performer in Model.Performers)
            {
                <tr>
                    <td>@performer.Name</td>
                    <td>@(string.IsNullOrWhiteSpace(performer.Bio) ? "-" : performer.Bio)</td>
                    @if (isAdmin)
                    {
                        <td>
                            <form asp-action="RemovePerformer" asp-route-id="@Model.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="performerId" value="@performer.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                            </form>
                        </td>
                    }
                </tr>
            }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">No performers assigned to this event.</div>
}

@if (isAdmin)
{
    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title">Assign performer</h5>
            @if (ViewBag.AllPerformersAssigned == true)
            {
                <p class="text-muted mb-0">All performers are already assigned to this event.</p>
            }
            else
            {
                <form asp-action="AssignPerformer" asp-route-id="@Model.Id" method="post" class="row g-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <div class="col-md-6">
                        <label for="performerId" class="form-label">Performer</label>
                        <select name="performerId" id="performerId" class="form-select" asp-items="ViewBag.AvailablePerformerItems" required>
                            <option value="">-- Select performer --</option>
                        </select>
                    </div>
                    <div class="col-md-auto">
                        <button type="submit" class="btn btn-primary">Assign performer</button>
                    </div>
                </form>
            }
        </div>
    </div>
}

<div class="form-group mt-3">
    @if (isAdmin)
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    }
    else if (isUser)
    {
        if (isAlreadyRegistered)
        {
            <div class="alert alert-info d-inline-block mb-0 me-2" role="alert">
                You are already registered for this event.
            </div>
            <form asp-action="CancelRegistration" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">Cancel registration</button>
            </form>
        }
        else
        {
            <form asp-action="Register" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success">Register for this event</button>
            </form>
        }
    }
    else if (isAnonymous)
    {
        <a asp-controller="User" asp-action="Login" asp-route-returnUrl="@Context.Request.Path" class="btn btn-success">
            Login to register
        </a>
    }

    <a asp-action="Index" class="btn btn-outline-primary">Back to List</a>
</div>
