@model EventManager.WebApp.ViewModels.EventSearchVM

@{
    ViewData["Title"] = "Search Events";
}

<h1>Search Events</h1>

<form asp-action="Search" method="GET">
    <div class="row mb-3">
        <div class="col-md-4">
            <input asp-for="Q" class="form-control" placeholder="Search by name, description, or location" />
        </div>

        <div class="col-md-3">
            <select asp-for="EventTypeId" asp-items="Model.EventTypeItems" class="form-select">
                <option value="">All event types</option>
            </select>
        </div>

        <div class="col-md-2">
            <select asp-for="OrderBy" class="form-select">
                <option value="id">Default</option>
                <option value="name">Name</option>
                <option value="starttime">Start Time</option>
                <option value="capacity">Capacity</option>
                <option value="location">Location</option>
                <option value="eventtype">Event Type</option>
            </select>
        </div>

        <div class="col-md-2">
            <select asp-for="Size" class="form-select">
                <option value="5">5</option>
                <option value="10">10</option>
                <option value="20">20</option>
            </select>
        </div>

        <div class="col-md-1">
            <input type="submit" value="Go" name="submit" class="btn btn-primary" />
        </div>
    </div>
</form>
@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New</a>
    </p>
}
<div id="searchPartialPlaceholder">
    <partial name="_SearchPartial" model="Model" />
</div>
