@model EventManager.WebApp.ViewModels.EventTypeVM

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Event Type</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
    </dl>
</div>

<div class="form-group">
    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="mt-3 btn btn-primary">Edit</a>
    }
    <a asp-action="Index" class="mt-3 btn btn-outline-primary">Back to List</a>
</div>
