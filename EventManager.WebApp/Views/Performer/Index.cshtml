@model IEnumerable<EventManager.WebApp.ViewModels.PerformerVM>

@{
    ViewData["Title"] = "Performers";
}

<h1>Performers</h1>

@if (TempData.ContainsKey("newPerformerName"))
{
    <div class="alert alert-primary" role="alert">
        A new performer @TempData["newPerformerName"] has been created.
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-outline-primary">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Bio)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @(string.IsNullOrWhiteSpace(item.Bio) ? "-" : item.Bio)
            </td>
            <td>
                <div class="btn-group">
                    @Html.ActionLink("Details", "Details", new { id = item.Id }, new { @class = "btn btn-outline-primary" })
                    @Html.ActionLink("Edit", "Edit", new { id = item.Id }, new { @class = "btn btn-outline-primary" })
                    @Html.ActionLink("Delete", "Delete", new { id = item.Id }, new { @class = "btn btn-outline-danger" })
                </div>
            </td>
        </tr>
}
    </tbody>
</table>
