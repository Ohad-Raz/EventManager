@model EventManager.WebApp.ViewModels.ProfileVM

@{
    ViewData["Title"] = "Profile";
}

<h1>My Profile</h1>

<div id="profileMessage" class="alert d-none" role="alert"></div>

<form id="profileForm">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Username" class="form-label"></label>
        <input asp-for="Username" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label asp-for="RoleName" class="form-label"></label>
        <input asp-for="RoleName" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label asp-for="FirstName" class="form-label"></label>
        <input asp-for="FirstName" class="form-control" id="FirstName" />
    </div>

    <div class="mb-3">
        <label asp-for="LastName" class="form-label"></label>
        <input asp-for="LastName" class="form-control" id="LastName" />
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" id="Email" />
    </div>

    <div class="mb-3">
        <label asp-for="Phone" class="form-label"></label>
        <input asp-for="Phone" class="form-control" id="Phone" />
    </div>

    <button type="button" id="saveProfileBtn" class="btn btn-primary">Save</button>
</form>

@section Scripts {
    <script src="~/js/profile.js" asp-append-version="true"></script>
}
